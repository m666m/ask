# Bash completion for 'ask' — provides AI‑generated command examples
# Place this file in /etc/bash_completion.d/ (system-wide) or
# in ~/.bash_completion.d/ (per-user). It will be sourced automatically.
# 调试：
#   $ complete -p ask
#   $ COMP_LINE="ask tar" _ask_completion
#   $ echo "${COMPREPLY[@]}"

_ask_completion() {
    local input="${COMP_LINE#ask }"
    [[ -z "$input" ]] && return

    local MODEL="${ASK_MODEL:-gemma4:26b}"
    local OLLAMA_URL="${ASK_OLLAMA_URL:-http://localhost:11434/v1/chat/completions}"

    command -v jq &>/dev/null || return
    command -v curl &>/dev/null || return

    # 构建上下文
    local files
    files=$(ls -A 2>/dev/null | head -20 | tr '\n' ' ')
    local system="You are a shell command example generator. Return 3~5 common usage examples of the given command. Format each line exactly as: 参数 (描述). No extra text."
    local full_prompt="OS: $(uname -s), pwd: $(pwd), files: $files\nPartial command: $input"

    # 调用 Ollama API
    local json_data
    json_data=$(jq -n \
        --arg model "$MODEL" \
        --arg sys "$system" \
        --arg usr "$full_prompt" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $sys},
                {role: "user", content: $usr}
            ],
            stream: false
        }')

    local output
    output=$(printf '%s' "$json_data" | \
        curl -s --connect-timeout 3 --max-time 8 -X POST "$OLLAMA_URL" \
        -H "Content-Type: application/json" -d @- 2>/dev/null | \
        jq -r '.choices[0].message.content // empty' 2>/dev/null)

    [[ -z "$output" ]] && return

    # 打印建议列表到 stderr
    echo "" >&2
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        printf '  %s\n' "$line" >&2
    done <<< "$output"

    # 提示用户如何退出（按 Ctrl+C 获得干净提示符）
    printf '\n  \033[1;33m--- Press Ctrl+C to get a clean prompt ---\033[0m\n' >&2

    # 不提供任何补全词
    COMPREPLY=()
}

complete -F _ask_completion ask
