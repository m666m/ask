#!/bin/bash
# 纯文本管道转发至 Ollama OpenAI 兼容 API
#
# 用法:
#
# 单行问题
# $ echo "Why the sky is blue?" | ask
#
# 多行问题
# $ cat << EOF | ask
# 请用 Python 写一个快速排序函数，
# 并添加详细注释。
# EOF
#
# 从文件读取问题
# $ ask < question.txt

set -euo pipefail

# 默认模型，可以根据需要修改为其他 Ollama 支持的模型
MODEL=${1:-"gemma4:26b"}
# NOTE: wsl 内访问宿主机 ollama 不能用 localhost，而是 172.21.16.1 这样的地址
OLLAMA_URL="http://localhost:11434/v1/chat/completions"

# 输入内容有引号等特殊字符可能会导致解析错误
USER_PROMPT=$(cat)

if ! command -v jq &>/dev/null; then
    echo "Error: jq not found" >&2
    exit 1
fi

JSON_DATA=$(jq -n \
    --arg model "$MODEL" \
    --arg content "$USER_PROMPT" \
    '{
        model: $model,
        messages: [{role: "user", content: $content}],
        stream: true
    }')

# 直接调用 curl 或 wget，不再拼接命令字符串
if command -v curl &>/dev/null; then
    printf '%s' "$JSON_DATA" | curl -s -N -X POST "$OLLAMA_URL" \
        -H "Content-Type: application/json" -d @-
elif command -v wget &>/dev/null; then
    printf '%s' "$JSON_DATA" | wget -q -O - --no-buffer \
        --header="Content-Type: application/json" \
        --post-file=- "$OLLAMA_URL"
else
    echo "Error: curl or wget not found" >&2
    exit 1
fi | while IFS= read -r line; do
    # 跳过空行
    [[ -z "$line" ]] && continue
    # 只处理 SSE 数据行
    if [[ "$line" == data:* ]]; then
        json_part="${line#data: }"
        # 忽略结束标记
        [[ "$json_part" == "[DONE]" ]] && continue
        # 提取内容，忽略解析错误（避免 pipefail 导致脚本退出）
        content=$(echo "$json_part" | jq -r '.choices[0].delta.content // empty' 2>/dev/null || true)
        if [[ -n "$content" ]]; then
            printf "%s" "$content"
        fi
    fi
done

# 最后补一个换行，使终端提示符另起一行
echo
