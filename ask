#!/bin/bash
# ask - AI 助手，支持管道输入与自然语言翻译为shell命令

set -euo pipefail

# 默认模型，可以根据需要修改为其他 Ollama 支持的模型
MODEL="${ASK_MODEL:-gemma4:26b}"
# NOTE: wsl 内访问宿主机 ollama 不能用 localhost，而是 172.21.16.1 这样的地址
OLLAMA_URL="${ASK_OLLAMA_URL:-http://localhost:11434/v1/chat/completions}"

if ! command -v jq &>/dev/null; then
    echo "Error: jq not found" >&2
    exit 1
fi

if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    echo "Error: curl or wget not found" >&2
    exit 1
fi

# ---------- 工具函数 ----------

# 非流式请求：发送 prompt，返回完整回答
# 用于 @ 模式，把用户的自然语言翻译成 shell 命令，
# 所以用提示词进行限制，输出使用非流式反应更快
ask_nonstream() {
    local system="$1"
    local user="$2"

    local json_data

    # 输入内容有引号等特殊字符可能会导致解析错误
    json_data=$(jq -n \
        --arg model "$MODEL" \
        --arg sys "$system" \
        --arg usr "$user" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $sys},
                {role: "user", content: $usr}
            ],
            stream: false
        }')

    if command -v curl &>/dev/null; then
        printf '%s' "$json_data" | curl -s --connect-timeout 5 --max-time 30 -X POST "$OLLAMA_URL" \
            -H "Content-Type: application/json" -d @- | jq -r '.choices[0].message.content // empty'
    elif command -v wget &>/dev/null; then
        printf '%s' "$json_data" | wget -q --timeout=30 -O - --header="Content-Type: application/json" \
            --post-file=- "$OLLAMA_URL" | jq -r '.choices[0].message.content // empty'
    fi
}

# 流式请求：发送 prompt，流式输出回答
# 用于管道模式和交互模式，不附加提示词，用户问题可能是分析log 等，让 AI 自行处理
ask_stream() {
    local user="$1"

    local json_data

    # 输入内容有引号等特殊字符可能会导致解析错误
    json_data=$(jq -n \
        --arg model "$MODEL" \
        --arg content "$user" \
        '{
            model: $model,
            messages: [{role: "user", content: $content}],
            stream: true
        }')

    if command -v curl &>/dev/null; then
        printf '%s' "$json_data" | curl -s --connect-timeout 5 --max-time 120 -N -X POST "$OLLAMA_URL" \
            -H "Content-Type: application/json" -d @-
    elif command -v wget &>/dev/null; then
        printf '%s' "$json_data" | wget -q --timeout=120 -O - --no-buffer \
            --header="Content-Type: application/json" \
            --post-file=- "$OLLAMA_URL"
    fi | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if [[ "$line" == data:* ]]; then
            json_part="${line#data: }"
            [[ "$json_part" == "[DONE]" ]] && continue
            content=$(echo "$json_part" | jq -r '.choices[0].delta.content // empty' 2>/dev/null || true)
            [[ -n "$content" ]] && printf "%s" "$content"
        fi
    done

    echo
}

# ---------- 模式分支 ----------

# 1. @ 模式：自然语言 → 命令（非流式）
# 用户输入 `ask @ 自然语言`，AI 直接翻译成 shell 命令
if [[ "${1:-}" == @* ]]; then
    natural_query="${1#@}"      # 去掉开头的 @
    shift

    # 拼接剩余参数（如果有）
    if [[ $# -gt 0 ]]; then
        natural_query="$natural_query $*"
    fi

    # 去除首尾空格
    natural_query="$(echo "$natural_query" | xargs)"

    if [[ -z "$natural_query" ]]; then
        echo "Usage: ask @ <natural language request>" >&2

        exit 1
    fi

    system_parts=(
    "You are a translator from natural language to a single shell command."
    "Return ONLY the exact command, no explanation, no markdown."
    "If there are multiple possible commands, choose the most common and safe one."
    )
    system=$(printf '%s\n' "${system_parts[@]}")

    user="Context: os:$(uname -s), current directory $(pwd), files: $(ls -A | head -20 | tr '\n' ' ')\nRequest: $natural_query"

    cmd=$(ask_nonstream "$system" "$user")
    # 清理并打印
    cmd=$(echo "$cmd" | grep -v '^\s*#' | head -1)
    printf '%s\n' "$cmd"

    exit 0
fi

# 2. 交互模式：ask 无参数且无管道输入
# 用户自由输入文字，或粘贴 log，然后按 Ctrl+D 即发送给 AI 进行分析
if [[ $# -eq 0 ]] && [[ -t 0 ]]; then
    # echo -n "ask> "
    # read -r USER_PROMPT
    echo "Enter or paste your question (press Ctrl+D when done):"
    USER_PROMPT=$(cat)

    if [[ -z "$USER_PROMPT" ]]; then
        echo "Empty input, exiting." >&2

        exit 1
    fi

    ask_stream "$USER_PROMPT"

    exit 0
fi

# 3. 管道模式：从 stdin 读取
USER_PROMPT=$(cat)

ask_stream "$USER_PROMPT"
