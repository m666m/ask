#!/bin/bash
# ask - AI 助手，支持管道输入与自然语言翻译为shell命令
#
#   设置环境变量 ASK_MODEL 和 ASK_OLLAMA_URL，否则需要编辑本文件进行设置
#
# 用法:
# 1、问问题
#
# 单行问题
# $ echo "Why the sky is blue?" | ask
#
# 多行问题
# $ cat << EOF | ask
# 请用 Python 写一个快速排序函数，
# 并添加详细注释。
# EOF
#
# 从文件读取问题
# $ ask < question.txt
#
# 2、自然语言转命令
# $ ask @ find files larger than 100M and sort by size
# find . -type f -size +100M -exec ls -lh {} \; 2>/dev/null | sort -k5 -h

set -euo pipefail

# TODO: 加载配置
# source ~/.config/ask/.env
# 默认模型，可以根据需要修改为其他 Ollama 支持的模型
MODEL="${ASK_MODEL:-gemma4:26b}"
# NOTE: wsl 内访问宿主机 ollama 不能用 localhost，而是 172.21.16.1 这样的地址
OLLAMA_URL="${ASK_OLLAMA_URL:-http://$(hostname).local:11434/v1/chat/completions}"

if ! command -v jq &>/dev/null; then
    echo "Error: jq not found" >&2

    exit 1
fi

# ========== 自然语言转命令模式：ask @ ... ==========
if [[ "${1:-}" == "@" ]]; then
    shift                     # 去掉 @
    natural_query="$*"
    if [[ -z "$natural_query" ]]; then
        echo "Usage: ask @ <natural language request to shell command>" >&2

        exit 1
    fi

    system="You are a translator from natural language to a single shell command. Return ONLY the exact command, no explanation, no markdown. If there are multiple possible commands, choose the most common and safe one."
    full_prompt="Context: current directory $(pwd), files: $(ls -A | head -20)\nRequest: $natural_query"

    JSON_DATA=$(jq -n \
        --arg model "$MODEL" \
        --arg sys "$system" \
        --arg usr "$full_prompt" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $sys},
                {role: "user", content: $usr}
            ],
            stream: false
        }')

    # 非流式请求
    if command -v curl &>/dev/null; then
        cmd=$(printf '%s' "$JSON_DATA" | curl -s -X POST "$OLLAMA_URL" \
            -H "Content-Type: application/json" -d @- | jq -r '.choices[0].message.content')
    elif command -v wget &>/dev/null; then
        cmd=$(printf '%s' "$JSON_DATA" | wget -q -O - --header="Content-Type: application/json" \
            --post-file=- "$OLLAMA_URL" | jq -r '.choices[0].message.content')
    else
        echo "Error: curl or wget not found" >&2

        exit 1
    fi

    # 清理并打印
    cmd=$(echo "$cmd" | grep -v '^\s*#' | head -1)
    printf '%s\n' "$cmd"

    exit 0
fi

# ========== 交互模式：直接输入 ask 时进入 ==========
if [[ $# -eq 0 ]] && [[ -t 0 ]]; then
    echo -n "ask> "
    read -r USER_PROMPT

    if [[ -z "$USER_PROMPT" ]]; then
        echo "Empty input, exiting." >&2
        exit 1
    fi

    # 直接构造请求并输出
    JSON_DATA=$(jq -n \
        --arg model "$MODEL" \
        --arg content "$USER_PROMPT" \
        '{
            model: $model,
            messages: [{role: "user", content: $content}],
            stream: true
        }')

    if command -v curl &>/dev/null; then
        printf '%s' "$JSON_DATA" | curl -s -N -X POST "$OLLAMA_URL" \
            -H "Content-Type: application/json" -d @-
    elif command -v wget &>/dev/null; then
        printf '%s' "$JSON_DATA" | wget -q -O - --no-buffer \
            --header="Content-Type: application/json" \
            --post-file=- "$OLLAMA_URL"
    fi | while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if [[ "$line" == data:* ]]; then
            json_part="${line#data: }"
            [[ "$json_part" == "[DONE]" ]] && continue
            content=$(echo "$json_part" | jq -r '.choices[0].delta.content // empty' 2>/dev/null || true)
            if [[ -n "$content" ]]; then
                printf "%s" "$content"
            fi
        fi
    done

    echo
    exit 0
fi

# ========== 管道模式 ==========
# 输入内容有引号等特殊字符可能会导致解析错误
USER_PROMPT=$(cat)

JSON_DATA=$(jq -n \
    --arg model "$MODEL" \
    --arg content "$USER_PROMPT" \
    '{
        model: $model,
        messages: [{role: "user", content: $content}],
        stream: true
    }')

# 直接调用 curl 或 wget，不再拼接命令字符串
if command -v curl &>/dev/null; then
    printf '%s' "$JSON_DATA" | curl -s -N -X POST "$OLLAMA_URL" \
        -H "Content-Type: application/json" -d @-
elif command -v wget &>/dev/null; then
    printf '%s' "$JSON_DATA" | wget -q -O - --no-buffer \
        --header="Content-Type: application/json" \
        --post-file=- "$OLLAMA_URL"
else
    echo "Error: curl or wget not found" >&2

    exit 1
fi | while IFS= read -r line; do
    # 跳过空行
    [[ -z "$line" ]] && continue
    # 只处理 SSE 数据行
    if [[ "$line" == data:* ]]; then
        json_part="${line#data: }"
        # 忽略结束标记
        [[ "$json_part" == "[DONE]" ]] && continue
        # 提取内容，忽略解析错误（避免 pipefail 导致脚本退出）
        content=$(echo "$json_part" | jq -r '.choices[0].delta.content // empty' 2>/dev/null || true)
        if [[ -n "$content" ]]; then
            printf "%s" "$content"
        fi
    fi
done

# 最后补一个换行，使终端提示符另起一行
echo
